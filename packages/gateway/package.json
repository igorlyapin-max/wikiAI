{
  "name": "@wiki-ai/gateway",
  "version": "0.1.0",
  "description": "AI Search & Chat Gateway for MediaWiki",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration:local": "node scripts/integration-local.mjs",
    "test:smoke:llm": "node scripts/smoke-litellm.mjs",
    "migrate:postgres": "node scripts/migrate-sqlite-to-postgres.mjs",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/env": "^6.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sensible": "^6.0.4",
    "@qdrant/js-client-rest": "^1.12.0",
    "fastify": "^5.8.5",
    "ioredis": "^5.4.1",
    "pg": "^8.21.0",
    "undici": "^6.19.8",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^8.57.0",
    "tsx": "^4.15.0",
    "typescript": "^5.4.5",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
