{
  "name": "AIAssistant",
  "version": "0.1.0",
  "author": [
    "[Wiki AI Team]"
  ],
  "url": "https://github.com/...",
  "descriptionmsg": "aiassistant-desc",
  "license-name": "MIT",
  "type": "other",
  "requires": {
    "MediaWiki": ">= 1.39.0"
  },
  "AutoloadNamespaces": {
    "MediaWiki\\Extension\\AIAssistant\\": "src/"
  },
  "Hooks": {
    "PageSaveComplete": "hook",
    "PageDeleteComplete": "hook",
    "PageMoveComplete": "hook",
    "ArticleProtectComplete": "hook",
    "getUserPermissionsErrors": "hook"
  },
  "HookHandlers": {
    "hook": {
      "class": "MediaWiki\\Extension\\AIAssistant\\Hooks"
    }
  },
  "SpecialPages": {
    "AIAssistant": {
      "class": "MediaWiki\\Extension\\AIAssistant\\SpecialAIAssistant",
      "services": []
    },
    "AIAdmin": {
      "class": "MediaWiki\\Extension\\AIAssistant\\SpecialAIAdmin",
      "services": []
    }
  },
  "ExtensionMessagesFiles": {
    "AIAssistantAlias": "AIAssistant.alias.php"
  },
  "MessagesDirs": {
    "AIAssistant": [
      "i18n"
    ]
  },
  "ResourceModules": {
    "ext.aiassistant": {
      "scripts": [
        "resources/ai-assistant/dist/index.js"
      ],
      "styles": [
        "resources/ai-assistant/dist/index.css"
      ],
      "targets": [
        "desktop",
        "mobile"
      ]
    },
    "ext.aiadmin": {
      "scripts": [
        "resources/ai-admin/dist/index.js"
      ],
      "targets": [
        "desktop",
        "mobile"
      ]
    }
  },
  "ResourceFileModulePaths": {
    "localBasePath": "",
    "remoteExtPath": "AIAssistant"
  },
  "config": {
    "AIAssistantGatewayUrl": {
      "value": "",
      "description": "Internal or direct base URL of the AI Gateway. Leave empty for same-origin reverse proxy /api routes."
    },
    "AIAssistantGatewayPublicUrl": {
      "value": "",
      "description": "Optional browser-facing base URL of the AI Gateway. When empty, Docker-local hosts such as gateway or host.docker.internal are converted to the current wiki hostname."
    },
    "AIAssistantSyncerUrl": {
      "value": "http://syncer:3001",
      "description": "Base URL of the Syncer webhook endpoint"
    },
    "AIAssistantWebhookSecret": {
      "value": "",
      "description": "Shared HMAC-SHA256 secret for signing Syncer webhook events"
    },
    "AIAssistantPageAclRules": {
      "value": [],
      "description": "Optional test-stand page-level read ACL rules. Each rule supports title or prefix and groups."
    }
  },
  "manifest_version": 2,
  "GroupPermissions": {
    "sysop": {
      "aiadmin": true
    },
    "aiadmin": {
      "aiadmin": true
    }
  },
  "AvailableRights": [
    "aiadmin"
  ]
}
