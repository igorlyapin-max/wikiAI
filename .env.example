# === EXTERNAL SERVICES (already deployed — do not modify) ===

# Redis (port 16379 on host)
REDIS_URL=redis://localhost:16379/0

# Admin configuration DB. Use SQLite for dev/test/pilot.
DATABASE_URL=sqlite://./state/wiki-ai.sqlite

# LiteLLM Proxy (port 4000)
LITELLM_BASE_URL=http://localhost:4000/v1
# Required when Gateway talks to LiteLLM. Do not commit real keys.
LITELLM_API_KEY=
LITELLM_MODEL=corp-openai-gpt-4.1-mini
# Required in the LiteLLM runtime, not in WikiAI, when the LiteLLM route points to OpenAI.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# vLLM CPU (port 8000, direct access if needed)
VLLM_BASE_URL=http://localhost:8000

# MediaWiki
MW_BASE_URL=http://localhost:8082
MW_PUBLIC_BASE_URL=http://localhost:8082
MW_API_PATH=/api.php
# Preferred for protected namespace reindex: a dedicated MediaWiki service user
# from ai-exec/aiadmin or another group allowed by NAMESPACE_ACL/read ACL.
MW_SERVICE_USERNAME=WikiAISync
# Choose one password mode:
# 1. Direct value from env/config manager:
MW_SERVICE_PASSWORD=
# 2. Secret reference resolved by the configured provider:
# MW_SERVICE_PASSWORD=secret://Vault/MediaWiki/wikiai-syncer
# 3. Companion secret name. It is treated as secret://<value> when password is empty:
MW_SERVICE_PASSWORD_SECRET=
# Deprecated fallback only. Runtime session cookies expire and should not be the
# primary deployment mechanism for customer environments.
MW_SYNC_COOKIE=

# Optional secret provider for MW_SERVICE_PASSWORD=secret://... or MW_SERVICE_PASSWORD_SECRET.
# Supported provider: IndeedPamAapm. Leave None for direct MW_SERVICE_PASSWORD.
SECRETS_PROVIDER=None
PAMURL=
PAMTOKEN=
PAMTOKENFILE=
PAMUSERNAME=
PAMPASSWORD=
PAMDEFAULTACCOUNTPATH=
PAMPASSWORDENDPOINTPATH=/sc_aapm_ui/rest/aapm/password
PAMRESPONSETYPE=json
PAMVALUEJSONPATH=password
PAM_SEND_APPLICATION_CREDENTIALS_IN_QUERY=false
PAMPASSWORDEXPIRATIONINMINUTE=
PAMPASSWORDCHANGEREQUIRED=
PAMCOMMENT=wikiai {service} {secretId}
PAMTENANTID=
PAMPIN=
PAMTIMEOUTMS=10000
# Corporate seed script credentials for a test stand. Do not commit real values.
MW_ADMIN_USER=Admin
MW_ADMIN_PASSWORD=
MW_SEED_PASSWORD=

# Ollama (for embeddings)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Optional on-prem ColBERT late-interaction index. Search stays in current mode until enabled in Admin UI.
COLBERT_BASE_URL=http://localhost:8083
COLBERT_MODEL=antoinelouis/colbert-xm
COLBERT_COLLECTION=wiki_colbert_chunks
COLBERT_DEVICE=cpu
COLBERT_MAX_TOKENS=180

# === SELF-MANAGED SERVICES ===

# Qdrant (via docker-compose)
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=wiki_chunks

# AI Gateway
GATEWAY_PORT=3000
NODE_ENV=development
USER_GROUPS_CACHE_TTL=300
SYNCER_BASE_URL=http://localhost:3001
# Optional shared token for Gateway -> Syncer admin endpoints.
SYNCER_ADMIN_TOKEN=
# Comma-separated origins allowed for local standalone UI. Production should use same-origin /api/* proxy.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8082,http://127.0.0.1:8082

# External REST API and MCP. Disabled by default; can also be managed in Admin UI.
EXTERNAL_API_ENABLED=false
EXTERNAL_MCP_ENABLED=false
EXTERNAL_ANONYMOUS_SEARCH_ALLOWED=true
EXTERNAL_MAX_TOP_K=10
# mediawiki_check asks MediaWiki readable API after retrieval. groups_only trusts indexed allowed_groups.
EXTERNAL_ACL_MODE=mediawiki_check
# OIDC Bearer auth for third-party apps/MCP. Leave empty until configured by the customer IdP.
OIDC_ISSUER=
OIDC_AUDIENCE=
OIDC_JWKS_URL=
OIDC_SUBJECT_CLAIM=sub
OIDC_USERNAME_CLAIM=preferred_username
OIDC_GROUPS_CLAIM=groups

# Syncer
SYNCER_PORT=3001
GATEWAY_BASE_URL=http://localhost:3000
CHUNK_SIZE=512
CHUNK_OVERLAP=50
NAMESPACE_ACL={"0":["*"],"3000":["*"],"3010":["ai-hr","ai-exec"],"3020":["ai-finance","ai-exec"],"3030":["ai-it","ai-exec"],"3040":["sysop","aiadmin","ai-exec"]}
SMW_SYNC_ENABLED=true
SMW_SYNC_PROPERTIES=Департамент,Отдел,Тип документа,Владелец процесса,Статус документа,Система,Процесс,Дата действия,Критичность
