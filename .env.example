# === EXTERNAL SERVICES (already deployed — do not modify) ===

# Redis (port 16379 on host)
REDIS_URL=redis://localhost:16379/0

# LiteLLM Proxy (port 4000)
LITELLM_BASE_URL=http://localhost:4000/v1
LITELLM_API_KEY=sk-dev-litellm-master-key
LITELLM_MODEL=hosted_vllm/facebook/opt-125m

# vLLM CPU (port 8000, direct access if needed)
VLLM_BASE_URL=http://localhost:8000

# MediaWiki
MW_BASE_URL=http://localhost:8082
MW_API_PATH=/api.php

# Ollama (for embeddings)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# === SELF-MANAGED SERVICES ===

# Qdrant (via docker-compose)
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=wiki_chunks

# AI Gateway
GATEWAY_PORT=3000
NODE_ENV=development
USER_GROUPS_CACHE_TTL=300

# Syncer
SYNCER_PORT=3001
CHUNK_SIZE=512
CHUNK_OVERLAP=50
NAMESPACE_ACL={"0":["*"]}
