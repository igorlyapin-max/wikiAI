{
  "version": 1,
  "enabled": true,
  "defaultServer": "typescript",
  "servers": {
    "typescript": {
      "command": "omk",
      "args": [
        "lsp",
        "typescript"
      ],
      "languages": [
        "typescript",
        "typescriptreact",
        "javascript",
        "javascriptreact"
      ],
      "rootPatterns": [
        "tsconfig.json",
        "jsconfig.json",
        "package.json"
      ],
      "bundled": true,
      "description": "Bundled TypeScript LSP via typescript-language-server --stdio"
    }
  }
}
