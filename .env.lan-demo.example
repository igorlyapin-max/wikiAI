# Copy this file to .env.lan-demo and replace 192.168.1.50 with the host LAN IP.
#
# This is an opt-in demo profile for a trusted local network. The default
# docker-compose.yml still binds Gateway to 127.0.0.1 unless this file is loaded.

WIKIAI_LAN_HOST=192.168.1.50
WIKIAI_LAN_BIND=0.0.0.0

# Browser-facing MediaWiki URL used in Gateway source links.
MW_PUBLIC_BASE_URL=http://192.168.1.50:8082

# Browser origins allowed to call Gateway directly during LAN demos.
CORS_ORIGINS=http://192.168.1.50:8082,http://localhost:8082,http://127.0.0.1:8082

# MediaWiki LocalSettings.php companion value:
# $wgAIAssistantGatewayPublicUrl = 'http://192.168.1.50:3000';
